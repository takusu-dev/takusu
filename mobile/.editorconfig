root = true

[*.{kt,kts}]
# ktlint configuration — see https://pinterest.github.io/ktlint/latest/rules/configuration/
max_line_length = 120
indent_style = space
indent_size = 4
insert_final_newline = true

# Exclude UniFFI-generated bindings (auto-generated, not hand-edited).
# ktlint respects .gitignore by default, but the UniFFI file is tracked
# in the repo so we need an explicit exclude pattern.
ij_kotlin_imports_layout = *
ktlint_standard_no-wildcard-imports = disabled
