<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical"
  android:padding="12dp"
  android:background="@drawable/widget_background">

  <!-- Doing task section (fixed at top) -->
  <LinearLayout
    android:id="@+id/widget_doing_section"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="6dp">

    <TextView
      android:id="@+id/widget_doing_label"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textSize="11sp"
      android:textColor="#4ECDC4"
      android:textStyle="bold"
      android:layout_marginBottom="2dp" />

    <TextView
      android:id="@+id/widget_doing_title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textSize="14sp"
      android:textColor="#FFFFFF"
      android:textStyle="bold"
      android:maxLines="3"
      android:ellipsize="end" />
  </LinearLayout>

  <!-- Upcoming tasks label -->
  <TextView
    android:id="@+id/widget_upcoming_label"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:textSize="11sp"
    android:textColor="#AAAAAA"
    android:layout_marginBottom="4dp" />

  <!-- Scrollable upcoming tasks list -->
  <ListView
    android:id="@+id/widget_upcoming_list"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:background="@android:color/transparent"
    android:cacheColorHint="@android:color/transparent"
    android:divider="@null"
    android:dividerHeight="0dp"
    android:overScrollMode="never" />

  <!-- Footer: unscheduled count + last updated -->
  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginTop="4dp">

    <TextView
      android:id="@+id/widget_unscheduled"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:textSize="11sp"
      android:textColor="#888888" />

    <TextView
      android:id="@+id/widget_updated"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textSize="10sp"
      android:textColor="#666666" />
  </LinearLayout>

</LinearLayout>
