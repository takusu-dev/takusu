<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_background"
  android:orientation="vertical"
  android:paddingLeft="20dp"
  android:paddingRight="20dp"
  android:paddingTop="16dp"
  android:paddingBottom="24dp">

  <LinearLayout
    android:id="@+id/widget_header"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/widget_brand_icon"
      android:layout_width="22dp"
      android:layout_height="22dp"
      android:background="@drawable/brand_icon_bg"
      android:gravity="center"
      android:text="t"
      android:textColor="@color/takusu_widget_white"
      android:textSize="12sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_brand_name"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="8dp"
      android:text="takusu"
      android:textColor="@color/takusu_widget_text"
      android:textSize="15sp"
      android:textStyle="bold" />

    <View
      android:layout_width="0dp"
      android:layout_height="0dp"
      android:layout_weight="1" />

    <TextView
      android:id="@+id/widget_updated"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textColor="@color/takusu_widget_text_muted"
      android:textSize="10sp" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/widget_doing_section"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/doing_bg"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
      android:id="@+id/widget_doing_label"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="進行中"
      android:textColor="@color/takusu_widget_brand_light"
      android:textSize="11sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_doing_title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:ellipsize="end"
      android:maxLines="2"
      android:textColor="@color/takusu_widget_text"
      android:textSize="16sp"
      android:textStyle="bold" />

    <LinearLayout
      android:id="@+id/widget_doing_meta"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/widget_doing_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/takusu_widget_text_muted"
        android:textSize="11sp" />

      <TextView
        android:id="@+id/widget_doing_remaining"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/takusu_widget_text_muted"
        android:textSize="11sp" />
    </LinearLayout>

    <ProgressBar
      android:id="@+id/widget_doing_progress"
      style="?android:attr/progressBarStyleHorizontal"
      android:layout_width="match_parent"
      android:layout_height="4dp"
      android:layout_marginTop="6dp"
      android:max="100"
      android:progressDrawable="@drawable/progress_bar" />
  </LinearLayout>

  <TextView
    android:id="@+id/widget_upcoming_label"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:text="次のタスク"
    android:textColor="@color/takusu_widget_text_muted"
    android:textSize="10sp"
    android:textStyle="bold" />

  <ListView
    android:id="@+id/widget_upcoming_list"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="5dp"
    android:layout_weight="1"
    android:background="@android:color/transparent"
    android:cacheColorHint="@android:color/transparent"
    android:divider="@null"
    android:dividerHeight="0dp"
    android:overScrollMode="never" />

  <LinearLayout
    android:id="@+id/widget_empty"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:gravity="center"
    android:orientation="vertical"
    android:visibility="gone">

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:alpha="0.35"
      android:text="☽"
      android:textColor="@color/takusu_widget_text_muted"
      android:textSize="28sp" />

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="今日の予定はまだありません"
      android:textColor="@color/takusu_widget_text"
      android:textSize="14sp" />

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:text="アプリを開いてタスクを追加"
      android:textColor="@color/takusu_widget_text_muted"
      android:textSize="12sp" />
  </LinearLayout>

  <RelativeLayout
    android:id="@+id/widget_footer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp">

    <TextView
      android:id="@+id/widget_unscheduled"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_alignParentStart="true"
      android:layout_centerVertical="true"
      android:background="@drawable/unscheduled_chip_bg"
      android:paddingLeft="8dp"
      android:paddingRight="8dp"
      android:paddingTop="3dp"
      android:paddingBottom="3dp"
      android:textColor="@color/takusu_widget_must"
      android:textSize="10sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_open_btn"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_alignParentEnd="true"
      android:layout_centerVertical="true"
      android:background="@drawable/open_btn_bg"
      android:paddingLeft="10dp"
      android:paddingRight="10dp"
      android:paddingTop="4dp"
      android:paddingBottom="4dp"
      android:text="開く"
      android:textColor="@color/takusu_widget_brand_light"
      android:textSize="11sp"
      android:textStyle="bold" />
  </RelativeLayout>
</LinearLayout>
