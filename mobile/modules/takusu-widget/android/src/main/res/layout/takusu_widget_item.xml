<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_item_root"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@drawable/item_bg"
  android:gravity="center_vertical"
  android:minHeight="34dp"
  android:orientation="horizontal"
  android:paddingLeft="8dp"
  android:paddingRight="8dp"
  android:paddingTop="6dp"
  android:paddingBottom="6dp">

  <TextView
    android:id="@+id/widget_item_time"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/time_chip_bg"
    android:paddingLeft="6dp"
    android:paddingRight="6dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp"
    android:textColor="@color/takusu_widget_text"
    android:textSize="10sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/widget_item_dot"
    android:layout_width="7dp"
    android:layout_height="7dp"
    android:layout_marginStart="10dp"
    android:gravity="center"
    android:includeFontPadding="false"
    android:text="●"
    android:textSize="6sp" />

  <TextView
    android:id="@+id/widget_item_title"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_weight="1"
    android:ellipsize="end"
    android:maxLines="1"
    android:textColor="@color/takusu_widget_text"
    android:textSize="13sp" />

  <TextView
    android:id="@+id/widget_item_fixed"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="6dp"
    android:background="@drawable/fixed_badge_bg"
    android:paddingLeft="6dp"
    android:paddingRight="6dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp"
    android:text="固定"
    android:textColor="@color/takusu_widget_white"
    android:textSize="9sp"
    android:textStyle="bold" />
</LinearLayout>
